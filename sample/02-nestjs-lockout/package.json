{
  "name": "authlock-nestjs-sample",
  "version": "0.0.0",
  "private": true,
  "description": "A NestJS app dogfooding @nest-native/lockout end to end — LockoutModule + LockoutGuard + LockoutService on a real login route over HTTP.",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "smoke": "ts-node --transpile-only scripts/smoke.ts",
    "test": "npm run typecheck && npm run smoke"
  },
  "dependencies": {
    "@authlock/core": "0.2.0",
    "@nest-native/lockout": "0.2.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^26.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
